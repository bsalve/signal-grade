<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Local SEO Audit — {{url}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    @page { size: A4; margin: 0; }

    :root {
      --bg:     #0b0c0e;
      --bg2:    #111214;
      --border: #1e2025;
      --dim2:   #2a2d35;
      --text:   #e4e6ea;
      --muted:  #8892a4;
      --accent: #4d9fff;
      --warn:   #ffb800;
      --fail:   #ff4455;
      --pass:   #34d399;
    }

    html, body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Space Mono', 'Courier New', monospace;
      font-size: 12px;
      line-height: 1.6;
    }

    .page {
      padding: 14mm 14mm 20mm;
    }

    /* ── HEADER ── */
    .doc-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      padding-bottom: 14px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 28px;
    }

    .doc-meta-label {
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 6px;
    }
    .doc-meta-label span { color: var(--accent); }

    .doc-meta-cats {
      font-size: 9px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-top: 4px;
    }
    .cat-technical { color: #8892a4; }
    .cat-content   { color: #e8a87c; }
    .cat-aeo       { color: #7baeff; }
    .cat-geo       { color: #b07bff; }
    .cat-sep { color: var(--dim2); margin: 0 4px; }

    .doc-url {
      font-size: 16px;
      font-weight: 700;
      color: var(--text);
      word-break: break-all;
      max-width: 460px;
    }

    .doc-date {
      font-size: 10px;
      text-align: right;
      white-space: nowrap;
      padding-top: 20px;
    }
    .doc-date .date-label {
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 2px;
    }
    .doc-date .date-val {
      color: var(--text);
    }

    /* ── SCORE BLOCK ── */
    .score-block {
      display: flex;
      align-items: flex-start;
      gap: 28px;
      margin-bottom: 20px;
      padding: 22px 24px;
      background: var(--bg2);
      border: 1px solid var(--border);
      border-top: 3px solid var(--accent);
    }

    .grade-letter {
      font-size: 96px;
      font-weight: 700;
      line-height: 1;
      letter-spacing: -0.04em;
      flex-shrink: 0;
      width: 88px;
      text-align: center;
    }
    .grade-A { color: var(--pass); }
    .grade-B { color: var(--accent); }
    .grade-C { color: var(--warn); }
    .grade-D { color: #ff8800; }
    .grade-F { color: var(--fail); }

    .score-right {
      flex: 1;
      padding-top: 6px;
    }

    .score-number {
      font-size: 44px;
      font-weight: 700;
      line-height: 1;
      color: var(--text);
      margin-bottom: 6px;
    }
    .score-number .denom {
      font-size: 18px;
      font-weight: 400;
      color: var(--muted);
    }

    .score-summary {
      font-size: 11px;
      color: var(--muted);
      font-style: italic;
      margin-bottom: 18px;
    }

    .meter-label {
      font-size: 9px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 5px;
    }
    .meter-track {
      height: 6px;
      background: var(--border);
      margin-bottom: 4px;
    }
    .meter-fill { height: 100%; }
    .meter-ticks {
      display: flex;
      justify-content: space-between;
      font-size: 8px;
      color: var(--muted);
    }

    /* ── STATS ROW ── */
    .stats-row {
      display: flex;
      border: 1px solid var(--border);
      margin-bottom: 28px;
    }
    .stat-cell {
      flex: 1;
      padding: 14px 18px;
      border-right: 1px solid var(--border);
      background: var(--bg2);
    }
    .stat-cell:last-child { border-right: none; }
    .stat-n {
      font-size: 30px;
      font-weight: 700;
      line-height: 1;
      margin-bottom: 4px;
    }
    .stat-l {
      font-size: 9px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .stat-pass .stat-n { color: var(--pass); }
    .stat-warn .stat-n { color: var(--warn); }
    .stat-fail .stat-n { color: var(--fail); }

    /* ── CATEGORY SCORES ── */
    .cat-scores-row {
      display: flex;
      border: 1px solid #1e2025;
      margin-bottom: 28px;
    }
    .cat-score-cell {
      flex: 1;
      padding: 14px 16px;
      border-right: 1px solid #1e2025;
      background: #111214;
    }
    .cat-score-cell:last-child { border-right: none; }
    .cat-score-name {
      font-size: 9px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin-bottom: 6px;
    }
    .cat-score-num {
      font-size: 22px;
      font-weight: 700;
      line-height: 1;
      color: #e4e6ea;
      margin-bottom: 2px;
    }
    .cat-score-denom {
      font-size: 11px;
      font-weight: 400;
      color: #8892a4;
    }
    .cat-score-grade {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      margin-bottom: 8px;
    }
    .cat-mini-track {
      height: 3px;
      background: #2a2d35;
      overflow: hidden;
    }
    .cat-mini-fill { height: 100%; }

    /* ── SECTION / CATEGORY LABELS ── */
    .section-label {
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .cat-header {
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      margin: 20px 0 10px;
      display: flex;
      align-items: center;
      gap: 10px;
      border-top: 1px solid var(--border);
      padding-top: 16px;
    }
    .cat-header::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }
    .cat-header .cat-full {
      font-size: 8px;
      font-style: italic;
      letter-spacing: 0.08em;
      opacity: 0.7;
    }
    .cat-header.cat-technical { color: #8892a4; }
    .cat-header.cat-content   { color: #e8a87c; }
    .cat-header.cat-aeo       { color: #7baeff; }
    .cat-header.cat-geo       { color: #b07bff; }

    /* ── RESULT ROWS ── */
    .result-rows { display: flex; flex-direction: column; }

    .result-row {
      border-top: 1px solid var(--border);
      padding: 14px 0 14px 12px;
      display: grid;
      grid-template-columns: 16px 1fr auto;
      gap: 14px;
      align-items: start;
      break-inside: avoid;
      border-left: 2px solid transparent;
    }
    .result-row:last-child { border-bottom: 1px solid var(--border); }
    .result-row.row-pass { border-left-color: var(--pass); }
    .result-row.row-warn { border-left-color: var(--warn); }
    .result-row.row-fail { border-left-color: var(--fail); }

    .row-icon {
      font-size: 11px;
      font-weight: 700;
      margin-top: 1px;
    }
    .icon-pass { color: var(--pass); }
    .icon-warn { color: var(--warn); }
    .icon-fail { color: var(--fail); }

    .row-name {
      font-size: 12px;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 3px;
    }
    .row-msg {
      font-size: 11px;
      color: var(--muted);
      margin-bottom: 3px;
      white-space: pre-line;
    }
    .row-details {
      font-size: 10px;
      color: #6b7585;
      white-space: pre-line;
      font-style: italic;
      margin-bottom: 3px;
    }
    .row-rec {
      font-size: 10px;
      color: var(--muted);
      white-space: pre-line;
      margin-top: 8px;
      border-left: 2px solid var(--dim2);
      padding-left: 10px;
      line-height: 1.7;
    }
    .row-rec-label {
      font-size: 8px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #6b7585;
      margin-bottom: 2px;
    }

    .row-bar {
      grid-column: 2 / -1;
      height: 2px;
      background: var(--border);
      margin-top: 8px;
    }
    .row-bar-fill { height: 100%; }
    .bar-pass { background: var(--pass); }
    .bar-warn { background: var(--warn); }
    .bar-fail { background: var(--fail); }

    .row-score {
      font-size: 11px;
      font-weight: 700;
      white-space: nowrap;
      padding-top: 1px;
      text-align: right;
    }
    .rscore-pass { color: var(--pass); }
    .rscore-warn { color: var(--warn); }
    .rscore-fail { color: var(--fail); }
  </style>
</head>
<body>
<div class="page">

  <!-- Header -->
  <div class="doc-header">
    <div>
      <div class="doc-meta-label">LOCAL.<span>SEO</span>.AUDIT &nbsp;·&nbsp; REPORT</div>
      <div class="doc-meta-cats">
        <span class="cat-technical">Technical</span><span class="cat-sep">·</span><span class="cat-content">Content</span><span class="cat-sep">·</span><span class="cat-aeo">AEO</span><span class="cat-sep">·</span><span class="cat-geo">GEO</span>
      </div>
      <div class="doc-url">{{url}}</div>
    </div>
    <div class="doc-date">
      <div class="date-label">Audited</div>
      <div class="date-val">{{auditedAt}}</div>
    </div>
  </div>

  <!-- Score block -->
  <div class="score-block">
    <div class="grade-letter grade-{{grade}}">{{grade}}</div>
    <div class="score-right">
      <div class="score-number">{{totalScore}}<span class="denom"> / 100</span></div>
      <div class="score-summary">{{summary}}</div>
      <div class="meter-label">Overall Score</div>
      <div class="meter-track">
        <div class="meter-fill" style="width:{{totalScore}}%;background:{{meterColor}};"></div>
      </div>
      <div class="meter-ticks">
        <span>0</span><span>25</span><span>50</span><span>75</span><span>100</span>
      </div>
    </div>
  </div>

  <!-- Stats -->
  <div class="stats-row">
    <div class="stat-cell stat-pass">
      <div class="stat-n">{{passCount}}</div>
      <div class="stat-l">Passed</div>
    </div>
    <div class="stat-cell stat-warn">
      <div class="stat-n">{{warnCount}}</div>
      <div class="stat-l">Warnings</div>
    </div>
    <div class="stat-cell stat-fail">
      <div class="stat-n">{{failCount}}</div>
      <div class="stat-l">Failed</div>
    </div>
  </div>

  <!-- Category scores -->
  <div class="cat-scores-row">
    <div class="cat-score-cell" style="border-left:3px solid #8892a4">
      <div class="cat-score-name" style="color:#8892a4">Technical</div>
      <div class="cat-score-num">{{catScores.technical.score}}<span class="cat-score-denom">/100</span></div>
      <div class="cat-score-grade" style="color:#8892a4">{{catScores.technical.grade}}</div>
      <div class="cat-mini-track"><div class="cat-mini-fill" style="width:{{catScores.technical.score}}%;background:#8892a4;print-color-adjust:exact;-webkit-print-color-adjust:exact;"></div></div>
    </div>
    <div class="cat-score-cell" style="border-left:3px solid #e8a87c">
      <div class="cat-score-name" style="color:#e8a87c">Content</div>
      <div class="cat-score-num">{{catScores.content.score}}<span class="cat-score-denom">/100</span></div>
      <div class="cat-score-grade" style="color:#e8a87c">{{catScores.content.grade}}</div>
      <div class="cat-mini-track"><div class="cat-mini-fill" style="width:{{catScores.content.score}}%;background:#e8a87c;print-color-adjust:exact;-webkit-print-color-adjust:exact;"></div></div>
    </div>
    <div class="cat-score-cell" style="border-left:3px solid #7baeff">
      <div class="cat-score-name" style="color:#7baeff">AEO</div>
      <div class="cat-score-num">{{catScores.aeo.score}}<span class="cat-score-denom">/100</span></div>
      <div class="cat-score-grade" style="color:#7baeff">{{catScores.aeo.grade}}</div>
      <div class="cat-mini-track"><div class="cat-mini-fill" style="width:{{catScores.aeo.score}}%;background:#7baeff;print-color-adjust:exact;-webkit-print-color-adjust:exact;"></div></div>
    </div>
    <div class="cat-score-cell" style="border-left:3px solid #b07bff">
      <div class="cat-score-name" style="color:#b07bff">GEO</div>
      <div class="cat-score-num">{{catScores.geo.score}}<span class="cat-score-denom">/100</span></div>
      <div class="cat-score-grade" style="color:#b07bff">{{catScores.geo.grade}}</div>
      <div class="cat-mini-track"><div class="cat-mini-fill" style="width:{{catScores.geo.score}}%;background:#b07bff;print-color-adjust:exact;-webkit-print-color-adjust:exact;"></div></div>
    </div>
  </div>

  <!-- Technical Results -->
  <div class="section-label cat-technical">Technical — Site Health &amp; Infrastructure</div>
  <div class="result-rows">
    {{#each technicalResults}}
    <div class="result-row row-{{status}}">
      <div class="row-icon icon-{{status}}">
        {{#if (eq status "pass")}}✓{{else if (eq status "warn")}}△{{else}}✕{{/if}}
      </div>
      <div>
        <div class="row-name">{{name}}</div>
        {{#if message}}<div class="row-msg">{{message}}</div>{{/if}}
        {{#if details}}<div class="row-details">{{details}}</div>{{/if}}
        {{#if recommendation}}
        <div class="row-rec">
          <div class="row-rec-label">Recommendation</div>
          {{recommendation}}
        </div>
        {{/if}}
        {{#if (isDefined normalizedScore)}}
        <div class="row-bar">
          <div class="row-bar-fill bar-{{status}}" style="width:{{normalizedScore}}%"></div>
        </div>
        {{/if}}
      </div>
      <div class="row-score rscore-{{status}}">
        {{#if (isDefined normalizedScore)}}{{normalizedScore}}/100{{/if}}
      </div>
    </div>
    {{/each}}
  </div>

  <!-- Content Results -->
  {{#if contentResults.length}}
  <div class="cat-header cat-content">Content <span class="cat-full">— Marketing &amp; On-Page Signals</span></div>
  <div class="result-rows">
    {{#each contentResults}}
    <div class="result-row row-{{status}}">
      <div class="row-icon icon-{{status}}">
        {{#if (eq status "pass")}}✓{{else if (eq status "warn")}}△{{else}}✕{{/if}}
      </div>
      <div>
        <div class="row-name">{{name}}</div>
        {{#if message}}<div class="row-msg">{{message}}</div>{{/if}}
        {{#if details}}<div class="row-details">{{details}}</div>{{/if}}
        {{#if recommendation}}
        <div class="row-rec">
          <div class="row-rec-label">Recommendation</div>
          {{recommendation}}
        </div>
        {{/if}}
        {{#if (isDefined normalizedScore)}}
        <div class="row-bar">
          <div class="row-bar-fill bar-{{status}}" style="width:{{normalizedScore}}%"></div>
        </div>
        {{/if}}
      </div>
      <div class="row-score rscore-{{status}}">
        {{#if (isDefined normalizedScore)}}{{normalizedScore}}/100{{/if}}
      </div>
    </div>
    {{/each}}
  </div>
  {{/if}}

  <!-- AEO Results -->
  {{#if aeoResults.length}}
  <div class="cat-header cat-aeo">AEO <span class="cat-full">— Answer Engine Optimization</span></div>
  <div class="result-rows">
    {{#each aeoResults}}
    <div class="result-row row-{{status}}">
      <div class="row-icon icon-{{status}}">
        {{#if (eq status "pass")}}✓{{else if (eq status "warn")}}△{{else}}✕{{/if}}
      </div>
      <div>
        <div class="row-name">{{name}}</div>
        {{#if message}}<div class="row-msg">{{message}}</div>{{/if}}
        {{#if details}}<div class="row-details">{{details}}</div>{{/if}}
        {{#if recommendation}}
        <div class="row-rec">
          <div class="row-rec-label">Recommendation</div>
          {{recommendation}}
        </div>
        {{/if}}
        {{#if (isDefined normalizedScore)}}
        <div class="row-bar">
          <div class="row-bar-fill bar-{{status}}" style="width:{{normalizedScore}}%"></div>
        </div>
        {{/if}}
      </div>
      <div class="row-score rscore-{{status}}">
        {{#if (isDefined normalizedScore)}}{{normalizedScore}}/100{{/if}}
      </div>
    </div>
    {{/each}}
  </div>
  {{/if}}

  <!-- GEO Results -->
  {{#if geoResults.length}}
  <div class="cat-header cat-geo">GEO <span class="cat-full">— Generative Engine Optimization</span></div>
  <div class="result-rows">
    {{#each geoResults}}
    <div class="result-row row-{{status}}">
      <div class="row-icon icon-{{status}}">
        {{#if (eq status "pass")}}✓{{else if (eq status "warn")}}△{{else}}✕{{/if}}
      </div>
      <div>
        <div class="row-name">{{name}}</div>
        {{#if message}}<div class="row-msg">{{message}}</div>{{/if}}
        {{#if details}}<div class="row-details">{{details}}</div>{{/if}}
        {{#if recommendation}}
        <div class="row-rec">
          <div class="row-rec-label">Recommendation</div>
          {{recommendation}}
        </div>
        {{/if}}
        {{#if (isDefined normalizedScore)}}
        <div class="row-bar">
          <div class="row-bar-fill bar-{{status}}" style="width:{{normalizedScore}}%"></div>
        </div>
        {{/if}}
      </div>
      <div class="row-score rscore-{{status}}">
        {{#if (isDefined normalizedScore)}}{{normalizedScore}}/100{{/if}}
      </div>
    </div>
    {{/each}}
  </div>
  {{/if}}

</div>
</body>
</html>
